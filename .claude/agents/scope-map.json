{
  "_comment": "File scope per subagent. scope-enforce.sh reads this. Paths support glob wildcards. Precedence: denied > read_only > read_write.",
  "contract-dev": {
    "read_write": ["contracts/**"],
    "read_only":  ["docs/designs/**", ".claude/project/**", "apps/**/openapi*", "apps/**/*.graphql"],
